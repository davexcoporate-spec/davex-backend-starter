{
  "name": "davex-backend-starter",
  "version": "0.1.0",
  "private": true,
  "description": "Backend standardise DAVEX - clonable dans les projets clients",
  "main": "dist/core/server.js",
  "scripts": {
    "dev": "tsx watch src/core/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/core/server.js",
    "init-client": "tsx scripts/init-client.ts",
    "seed": "tsx scripts/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.5.0",
    "vitest": "^2.1.0"
  }
}
