# Base de donnees (Postgres standard - self-host, Neon, Railway, Render... au choix)
DATABASE_URL="postgresql://davex:davex@localhost:5432/davex_client?schema=public"

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# Serveur
PORT=4000
NODE_ENV=development

# Chemin vers le client.config.json du projet (copie depuis davex-starter)
CLIENT_CONFIG_PATH="./config/client.config.json"

# n8n (automation WhatsApp / notifications - webhooks)
N8N_WEBHOOK_BASE_URL="https://n8n.davexco.com/webhook"

# Compte admin par defaut (cree par `npm run seed`)
ADMIN_EMAIL="admin@davexco.com"
ADMIN_PASSWORD="change-me"
ADMIN_NAME="Admin"
